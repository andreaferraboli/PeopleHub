    <!-- Import guide screen -->
    <string name="import_guide_title">Guida all\'importazione</string>
    <string name="ig_intro">PeopleHub legge tre formati di file. Scegli un file in una qualsiasi delle sezioni qui sotto per importarlo, poi apri Cerchia o Ricorrenze per vedere i risultati.\n\nSuggerimento: esporta prima dalla Cassaforte — il file che crea ha esattamente questo formato, già compilato con i tuoi dati.</string>
    <string name="ig_fields">Campi</string>
    <string name="ig_example">Esempio</string>
    <string name="ig_required">obbligatorio</string>
    <string name="ig_optional">facoltativo</string>
    <string name="ig_result_dismiss">Ho capito</string>

    <string name="ig_csv_title">Compleanni · CSV</string>
    <string name="ig_csv_desc">Una persona per riga: nome, cognome, data di nascita. La riga di intestazione è facoltativa e rilevata automaticamente. Una riga errata viene saltata (non l\'intero file); racchiudi un campo tra virgolette per includere una virgola.</string>
    <string name="ig_csv_import">Scegli file CSV</string>

    <string name="ig_person_title">Una persona · JSON</string>
    <string name="ig_person_desc">Un singolo oggetto JSON che descrive una persona. Solo nome e cognome sono obbligatori; tutto il resto è facoltativo.</string>
    <string name="ig_person_import">Scegli profilo JSON</string>

    <string name="ig_backup_title">Backup completo · JSON</string>
    <string name="ig_backup_desc">L\'istantanea completa — persone, uscite ed eventi. Dopo aver scelto il file, seleziona Unisci per aggiungere solo i nuovi record o Sostituisci per sovrascrivere tutto.</string>
    <string name="ig_backup_import">Scegli file di backup</string>
